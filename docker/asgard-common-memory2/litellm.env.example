# LiteLLM proxy provider snippet. Merge these keys into the private .env.
# Never commit the real API key.
COGNEE_LLM_REQUIRED=false
COGNEE_LLM_PROVIDER=custom
# Cognee's GenericAPIAdapter calls LiteLLM; openai/<alias> routes to the
# OpenAI-compatible model alias exposed by the LiteLLM proxy.
COGNEE_LLM_MODEL=openai/REPLACE_WITH_LITELLM_MODEL_ALIAS
COGNEE_LLM_ENDPOINT=http://REPLACE_WITH_LITELLM_HOST:4000/v1
COGNEE_LLM_API_KEY=REPLACE_WITH_PRIVATE_LITELLM_KEY
