# Copy to .env with ./install.sh. .env is ignored and must never be committed.

COGNEE_PORT=8000
COGNEE_BIND_ADDRESS=0.0.0.0
COGNEE_LOG_LEVEL=INFO
COGNEE_CORS_ALLOWED_ORIGINS=

# LLM mapping is optional and may be unavailable on a given server. With
# COGNEE_LLM_REQUIRED=false install remains healthy but cognify/graph completion
# E2E is reported as DEGRADED until the provider becomes reachable.
COGNEE_LLM_REQUIRED=false
COGNEE_LLM_PROVIDER=ollama
COGNEE_LLM_MODEL=ollama/llama3.2:latest
COGNEE_LLM_ENDPOINT=http://host.docker.internal:11434/v1
COGNEE_LLM_API_KEY=ollama
# Host-side Ollama discovery used only by install diagnostics.
COGNEE_OLLAMA_PORT=11434
COGNEE_OLLAMA_MODEL=llama3.2:latest

# Generated by install.sh when these placeholders are present.
COGNEE_DEFAULT_USER_EMAIL=asgard-project-memory@nousresearch.com
COGNEE_DEFAULT_USER_PASSWORD=GENERATE_ON_INSTALL
COGNEE_VERIFICATION_SECRET=GENERATE_ON_INSTALL
COGNEE_RESET_SECRET=GENERATE_ON_INSTALL

COGNEE_CPU_LIMIT=6.0
COGNEE_MEMORY_LIMIT=12G
