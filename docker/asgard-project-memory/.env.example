# asgard-project-memory — cp .env.example .env 후 채우기. .env 는 커밋 금지 (.gitignore).
# 기본 구성 = MCP 도구 활성 + 관찰(observation)·Reflect 활성(호스트 ollama). README 참고.

# ── 필수 ──────────────────────────────────────────────────────────────────────
# PostgreSQL 비밀번호 (컨테이너 내부 전용 — 그래도 강한 값으로, URL-safe 문자만)
HINDSIGHT_DB_PASSWORD=

# ── LLM (관찰·Reflect 설정) ─────────────────────────────────────────────────
HINDSIGHT_LLM_PROVIDER=openai
HINDSIGHT_LLM_MODEL=qwen3:8b
HINDSIGHT_LLM_BASE_URL=http://host.docker.internal:11434/v1
# API 형 provider 로 바꿀 때만 (anthropic | openai | gemini | groq ...)
#HINDSIGHT_LLM_PROVIDER=anthropic
#HINDSIGHT_LLM_MODEL=claude-haiku-4-5
#HINDSIGHT_LLM_API_KEY=

# ── 선택 (기본값 있음) ─────────────────────────────────────────────────────────
# 관찰·Reflect 산출 언어 (compose 기본 Korean — 영어 운영이면 English 로)
#HINDSIGHT_LLM_OUTPUT_LANGUAGE=Korean

# mission 조향 — 기본 빈칸 확정(2026-07-23): Asgard 어댑터가 증류된 record 를 쓰므로
# 서버측 추출 조향은 왜곡 위험만 키운다. bank 별 observations/reflect mission 도 빈칸 유지.
#HINDSIGHT_RETAIN_MISSION=

# 이미지 태그 — 운영 안정화 후 특정 버전으로 핀 권장 (예: 0.8.4)
#HINDSIGHT_TAG=latest

# 호스트 포트 (macOS: 8888 이 OrbStack 등과 충돌하면 변경)
#HINDSIGHT_PORT=8888
#HINDSIGHT_UI_PORT=9999

# MCP 표면 (기본 켜짐, 무인증) — 내부망 밖 노출 시 false
#HINDSIGHT_MCP_ENABLED=true
# MCP 클라이언트에 얹을 배포별 사용 지침 (기본 빈칸)
#HINDSIGHT_MCP_INSTRUCTIONS=

# ── 내부망 OpenAI 호환 게이트웨이 연결 예시 (기본 채택 구성 — 상세 README §설계 결정) ──
#HINDSIGHT_LLM_PROVIDER=openai
#HINDSIGHT_LLM_MODEL=<게이트웨이 논리 모델명>
#HINDSIGHT_LLM_BASE_URL=http://<gateway-host>:<port>/v1
#HINDSIGHT_LLM_API_KEY=<게이트웨이 키>
# 게이트웨이 max-model-len 이 짧으면 retain 출력 상한을 함께 낮출 것
#HINDSIGHT_RETAIN_MAX_COMPLETION_TOKENS=8192
