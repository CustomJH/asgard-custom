# asgard-common-memory — cp .env.example .env 후 채우기. .env 는 커밋 금지 (.gitignore).

# ── 필수 ──────────────────────────────────────────────────────────────────────
# PostgreSQL 비밀번호 (컨테이너 내부 전용 — 그래도 강한 값으로)
HINDSIGHT_DB_PASSWORD=

# retain 용 LLM — 기본 provider=none (LLM 무연결: 추출 없이 원문 저장, 의미 검색은 내장 임베딩).
# 추출 품질이 필요하면 provider 를 anthropic(아래 키 필수) 또는 ollama(BASE_URL)로.
#HINDSIGHT_LLM_API_KEY=

# ── 선택 (기본값 있음) ─────────────────────────────────────────────────────────
# LLM provider/모델 — retain 추출용. recall 은 LLM 0 이라 비용은 쓰기에만 발생.
# anthropic | openai | gemini | groq | ollama ...
#HINDSIGHT_LLM_PROVIDER=anthropic
#HINDSIGHT_LLM_MODEL=claude-haiku-4-5
# ollama 등 커스텀 엔드포인트 — 호스트 ollama: http://host.docker.internal:11434/v1
# (구조화 출력 가능한 모델 필요 — qwen3:8b 급 이상, gemma4:12b 불가 실증)
#HINDSIGHT_LLM_BASE_URL=

# 이미지 태그 — 운영 안정화 후 특정 버전으로 핀 권장 (예: 0.8.4)
#HINDSIGHT_TAG=latest

# 호스트 포트 (macOS: 8888 이 OrbStack 등과 충돌하면 변경)
#HINDSIGHT_PORT=8888
#HINDSIGHT_UI_PORT=9999

# MCP 표면 (기본 켜짐, 무인증) — 내부망 밖 노출 시 false
#HINDSIGHT_MCP_ENABLED=true
