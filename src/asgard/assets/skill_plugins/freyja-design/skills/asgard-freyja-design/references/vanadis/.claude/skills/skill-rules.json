{
  "$schema": "./skill-rules.schema.json",
  "version": "0.2.0",
  "description": "vanadis v0.2 agent layer — skill registry. Lists skills available for orchestrated multi-agent workflows. Consumed by vanadis-orchestrator routing.",
  "skills": [
    {
      "id": "vanadis-orchestrator",
      "path": ".claude/skills/vanadis-orchestrator/SKILL.md",
      "agent": ".claude/agents/vanadis-orchestrator.md",
      "role": "supervisor",
      "user_invocable": true,
      "depends_on": [
        "vanadis-kr-writer",
        "vanadis-locale-adapter",
        "vanadis-designer-review",
        "vanadis-final-qa",
        "vanadis-codex-image"
      ]
    },
    {
      "id": "vanadis-kr-writer",
      "path": ".claude/skills/vanadis-kr-writer/SKILL.md",
      "agent": ".claude/agents/vanadis-kr-writer.md",
      "role": "writer",
      "user_invocable": true,
      "args": {
        "preset_id": {
          "type": "enum",
          "default": "toss-tech-design",
          "values": [
            "toss-tech-design",
            "karrot-neighborly",
            "brunch-maker-popular",
            "biz-formal-report",
            "academic-paper",
            "journalism-broadsheet"
          ],
          "spec": "data/research/2026-05-18-kr-style-presets.md"
        }
      }
    },
    {
      "id": "vanadis-locale-adapter",
      "path": ".claude/skills/vanadis-locale-adapter/SKILL.md",
      "agent": ".claude/agents/vanadis-locale-adapter.md",
      "role": "localizer",
      "user_invocable": true,
      "supports_locales": ["en", "ja", "zh-tw"],
      "source_locale": "ko"
    },
    {
      "id": "vanadis-designer-review",
      "path": ".claude/skills/vanadis-designer-review/SKILL.md",
      "agent": ".claude/agents/vanadis-designer-review.md",
      "role": "visual-critic",
      "user_invocable": true,
      "read_only": true,
      "revision_cap": 2
    },
    {
      "id": "vanadis-final-qa",
      "path": ".claude/skills/vanadis-final-qa/SKILL.md",
      "agent": ".claude/agents/vanadis-final-qa.md",
      "role": "final-critic",
      "user_invocable": true,
      "read_only": true,
      "revision_cap": 2
    },
    {
      "id": "vanadis-codex-image",
      "path": ".claude/skills/vanadis-codex-image/SKILL.md",
      "agent": ".claude/agents/vanadis-codex-image.md",
      "role": "image-materializer",
      "user_invocable": true,
      "channels": ["codex", "claude-code", "opencode"]
    }
  ],
  "orchestration": {
    "supervisor": "vanadis-orchestrator",
    "pattern": "anthropic-orchestrator-workers + langgraph-supervisor-revision-cap",
    "max_revision_rounds_per_gate": 2,
    "research_ref": "data/research/2026-05-18-agent-landscape.md"
  }
}
